# ── Last.fm ────────────────────────────────────────────────────────────────────
# Create an API account at https://www.last.fm/api/account/create
LASTFM_API_KEY=your_lastfm_api_key_here

# ── Spotify ─────────────────────────────────────────────────────────────────────
# Create an app at https://developer.spotify.com/dashboard
# Add https://api.dankcharts.fm/api/spotify/callback as a Redirect URI in the app settings
# NOTE: Dev Mode = max 5 authorized users. Apply for Extended Quota Mode for public launch.
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
SPOTIFY_REDIRECT_URI=https://api.dankcharts.fm/api/spotify/callback

# ── Supabase ────────────────────────────────────────────────────────────────────
# Create a free project at https://supabase.com/dashboard
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# ── App ─────────────────────────────────────────────────────────────────────────
# Where your frontend lives (used for OAuth redirects back to the site)
FRONTEND_URL=https://dankcharts.fm
# Comma-separated list of origins allowed to call this API
ALLOWED_ORIGINS=https://dankcharts.fm,http://localhost:3000
